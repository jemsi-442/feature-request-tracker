NODE_ENV=development
PORT=5001
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
DATABASE_URL=mysql://root:your_mysql_password@127.0.0.1:3306/feature_request_tracker
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=feature_request_tracker
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_DIALECT=mysql
DB_SYNC=true
DB_SYNC_ALTER=true
APP_NAME=Feature Request Tracker
MAIL_FROM=Feature Request Tracker <no-reply@example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_EMAIL=admin@feature-request-tracker.local
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_NAME=Feature Request Tracker Admin
AUTO_BOOTSTRAP_ADMIN=true